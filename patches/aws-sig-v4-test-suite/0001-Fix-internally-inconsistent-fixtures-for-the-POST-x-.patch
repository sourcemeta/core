\ No newline at end of file
diff --git a/raw/aws-sig-v4-test-suite/post-x-www-form-urlencoded/post-x-www-form-urlencoded.sts b/raw/aws-sig-v4-test-suite/post-x-www-form-urlencoded/post-x-www-form-urlencoded.sts
index 65ab663..fa3cb80 100755
--- a/raw/aws-sig-v4-test-suite/post-x-www-form-urlencoded/post-x-www-form-urlencoded.sts
+++ b/raw/aws-sig-v4-test-suite/post-x-www-form-urlencoded/post-x-www-form-urlencoded.sts
@@ -1,4 +1,4 @@
 AWS4-HMAC-SHA256
 20150830T123600Z
 20150830/us-east-1/service/aws4_request
-42a5e5bb34198acb3e84da4f085bb7927f2bc277ca766e6d19c73c2154021281
\ No newline at end of file
